# =============================================================================
# CWP Detailers — Combined environment template
# Copy to `.env` in repo root and fill in values:
#   cp .env.example .env
# =============================================================================

# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL (Neon or Render Postgres)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# API port (Render sets PORT automatically)
PORT=8080

# Cloudinary — required for staff before/after photos & DCMS visit images
# From https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=cwp/varanasi

# ── Super Admin (bootstrap + /admin/login) ──────────────────────────────────
# Phone = login ID at /admin/login. Password synced on every server start.
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=admin123
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@cwpdetailers.com

# ── Local dev frontend ──────────────────────────────────────────────────────

BASE_PATH=/

# ── Production (Render sets these via render.yaml) ──────────────────────────

# NODE_ENV=production
# STATIC_ROOT=artifacts/cwp-platform/dist/public
# LOG_LEVEL=info

# ── Wallet ──────────────────────────────────────────────────────────────────

# Low balance warning threshold (days of daily rate remaining)
WALLET_LOW_BALANCE_DAYS=7

# ── Daily Cleaning (DCMS) ───────────────────────────────────────────────────

# Comma-separated weekday numbers when cleaning is off (0=Sun … 6=Sat). Default: 3 (Wed)
# DAILY_CLEANING_OFF_DAYS=3

# ── Redis (communications job queue) ───────────────────────────────────────

# REDIS_URL=redis://localhost:6379

# ── SMS — FAST2SMS (primary) ────────────────────────────────────────────────
# https://www.fast2sms.com

FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=
# FAST2SMS_TEMPLATE_ID=

# ── SMS — MSG91 (fallback) ──────────────────────────────────────────────────

# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=

# ── Email (Resend) ──────────────────────────────────────────────────────────

# RESEND_API_KEY=

# ── Web Push (PWA browser notifications) ─────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
# VAPID_SUBJECT=mailto:admin@cwpdetailers.com

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@cwpdetailers.com

# ── Push notifications (FCM) — legacy, optional ───────────────────────────────

# FCM_SERVER_KEY=

# ── WhatsApp Business API ───────────────────────────────────────────────────

# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=cwp_verify

# ── Scripts / verification ──────────────────────────────────────────────────

# API_URL=http://localhost:8080/api

# ── Replit (auto-set on Replit; ignore locally) ─────────────────────────────

# REPL_ID=

# ── Pilot seed accounts (after `pnpm --filter @workspace/scripts run seed`) ─
# Admin credentials come from ADMIN_PHONE / ADMIN_PASSWORD above.
# Customer: phone 9001001001  password customer123  (Arjun Sharma)
# Customer: phone 9001001002  password customer123  (Sunita Patel)
# Customer: phone 9001001005  password customer123  (Rohit Agarwal)
# Staff:     phone 9011001001  password staff123     (Ravi Kumar)
# Staff:     phone 9011001002  password staff123     (Suresh Yadav)
