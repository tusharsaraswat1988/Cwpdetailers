# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL (Neon or Render Postgres)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Session signing key (generate a long random string)
SESSION_SECRET=

# API port (Render sets PORT automatically)
PORT=8080

# Cloudinary — required for staff before/after photos
# From https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=cwp/varanasi

# ── Local dev frontend ──────────────────────────────────────────────────────

BASE_PATH=/

# ── Production (Render sets these via render.yaml) ──────────────────────────

# STATIC_ROOT=artifacts/cwp-platform/dist/public
# NODE_ENV=production

# ── Phase 3 — Wallet & SMS ───────────────────────────────────────────────────

# Low balance warning threshold (days of daily rate remaining)
WALLET_LOW_BALANCE_DAYS=7

# FAST2SMS (primary SMS provider) — https://www.fast2sms.com
FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=
# FAST2SMS_TEMPLATE_ID=  # DLT template ID (optional)

# MSG91 (fallback SMS provider)
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=

# ── Pilot accounts (after `npx tsx scripts/src/seed.ts`) ───────────────────

# Admin:    phone 9999999999  password admin123
# Customer: phone 9001001001  password customer123
# Staff:    phone 9011001001  password staff123
