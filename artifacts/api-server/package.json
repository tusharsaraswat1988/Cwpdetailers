{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:serviceability": "vitest run src/lib/coverage src/lib/serviceability src/lib/location-intelligence",
    "test:coverage": "vitest run src/lib/coverage src/lib/location-intelligence",
    "test:address": "vitest run src/lib/address",
    "migrate:legacy-addresses": "tsx src/lib/address/migration/run-legacy-migration.ts"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.23",
    "@workspace/api-zod": "workspace:*",
    "@workspace/customer-model": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/validation": "workspace:*",
    "argon2": "^0.43.0",
    "bullmq": "^5.34.8",
    "cloudinary": "^2.6.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "express": "^5",
    "ioredis": "^5.6.1",
    "pdfkit": "^0.19.0",
    "pino": "^9",
    "pino-http": "^10",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.27.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pdfkit": "^0.17.6",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "vitest": "^3.2.4"
  }
}
